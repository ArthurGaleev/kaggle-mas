# ── LLM Provider API Keys ─────────────────────────────────────────────────────
# Set the key for the provider you want to use.
# The pipeline defaults to Groq (free tier, fast inference).

# Groq — free tier, very fast (recommended for development)
# Sign up at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter — unified gateway to many models (GPT-4o, Claude, Llama, etc.)
# Sign up at https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── HuggingFace ───────────────────────────────────────────────────────────────
# Used for HF Inference API and for pushing model weights to the Hub.
# Get a token at https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# ── Kaggle ────────────────────────────────────────────────────────────────────
# Required to download competition data via the Kaggle API.
# Find your credentials at https://www.kaggle.com/settings (API section).
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_key
